{
  "$schema": "https://capy.ai/schemas/capy-linear-slack-sync.v1.json",
  "enabled": false,
  "enablement": {
    "default": false,
    "requiresDeploymentOverride": true,
    "reason": "prevent accidental Linear or Slack writes during rollout and testing"
  },
  "linear": {
    "projects": [
      {
        "name": "Multica Ultimate Workbench"
      },
      {
        "name": "Windburn Remote Workhorse"
      }
    ],
    "statuses": [
      "Todo",
      "In Progress",
      "In Review",
      "Ready for Merge",
      "Done",
      "Blocked"
    ]
  },
  "slack": {
    "defaultChannel": {
      "name": "#everos-ops",
      "id": "C0ASVU15ZDY"
    },
    "blockerChannel": {
      "name": "#everos-ops",
      "id": "C0ASVU15ZDY"
    },
    "excludedChannels": [
      {
        "name": "#社交",
        "id": "C0ASM56QYUW"
      }
    ]
  },
  "notify": {
    "blocked": true,
    "ciFailed": true,
    "highCriticalReviewFinding": true,
    "needsOwnerDecision": true,
    "readyForMerge": true,
    "taskStarted": false,
    "commitPushed": false,
    "minorNit": false
  },
  "evidenceGates": {
    "sourceOfTruth": [
      "git",
      "github",
      "ci",
      "review-comments"
    ],
    "sourceOfTruthReferences": [
      "git commits and repo diffs",
      "github pull requests",
      "ci checks",
      "github review comments and findings"
    ],
    "inProgress": {
      "requiresWorkStartEvidence": true
    },
    "inReview": {
      "requiresPrOrReviewReadyEvidence": true
    },
    "readyForMerge": {
      "requiresPr": true,
      "requiresPassingRequiredChecks": true,
      "requiresNoOpenHighCriticalReviewFindings": true
    },
    "done": {
      "requiresMergedPr": true
    },
    "precedence": {
      "classifySemanticStateFromPrimaryEvidenceFirst": true,
      "durableGitHubOrRepoEvidenceOverridesSupportingMismatch": true,
      "externalWriteFailureKeepsSemanticStateAndFlagsSurface": true,
      "blockedOnlyWhenTrustworthyStateDecisionIsPrevented": true
    },
    "blockedWhen": [
      "required ci checks fail",
      "requirement is unclear",
      "high or critical review finding is open",
      "required primary evidence cannot be read",
      "primary github, ci, or review evidence conflicts and cannot be resolved safely"
    ],
    "flagWhen": [
      "semantic state is clear but linear auth, tooling, or write permission fails",
      "semantic state is clear but slack auth, tooling, or write permission fails",
      "durable github or repo evidence resolves a mismatch against chat, memory, linear, slack, or another supporting surface"
    ]
  },
  "forbiddenData": [
    "api keys",
    "oauth material",
    "bearer tokens",
    "cookies",
    "passwords",
    "raw request payloads",
    "raw response payloads",
    "raw transcripts",
    "private screenshots",
    "private browser traces",
    "unrelated private UI"
  ],
  "authority": {
    "capyCanMoveLinearStatus": true,
    "capyCanCommentLinear": true,
    "capyCanPostSlack": true,
    "capyCanMerge": false,
    "buildAgentsCanWriteExternalStatus": false
  }
}
