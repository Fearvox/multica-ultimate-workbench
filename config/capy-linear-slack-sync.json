{
  "$schema": "https://capy.ai/schemas/capy-linear-slack-sync.v1.json",
  "enabled": false,
  "enablement": {
    "default": false,
    "requiresDeploymentOverride": true,
    "reason": "prevent accidental Linear or Slack writes during rollout and testing"
  },
  "linear": {
    "projects": [
      {
        "name": "Multica Ultimate Workbench"
      },
      {
        "name": "Windburn Remote Workhorse"
      }
    ],
    "statuses": [
      "Todo",
      "In Progress",
      "In Review",
      "Ready for Merge",
      "Done",
      "Blocked"
    ]
  },
  "slack": {
    "defaultChannel": {
      "name": "#everos-ops",
      "id": "C0ASVU15ZDY"
    },
    "blockerChannel": {
      "name": "#everos-ops",
      "id": "C0ASVU15ZDY"
    },
    "excludedChannels": [
      {
        "name": "#社交",
        "id": "C0ASM56QYUW"
      }
    ]
  },
  "notify": {
    "blocked": true,
    "ciFailed": true,
    "highCriticalReviewFinding": true,
    "needsOwnerDecision": true,
    "readyForMerge": true,
    "taskStarted": false,
    "commitPushed": false,
    "minorNit": false
  },
  "evidenceGates": {
    "sourceOfTruth": [
      "git",
      "github",
      "ci",
      "review-comments"
    ],
    "sourceOfTruthReferences": [
      "git commits and repo diffs",
      "github pull requests",
      "ci checks",
      "github review comments and findings"
    ],
    "inProgress": {
      "requiresWorkStartEvidence": true
    },
    "inReview": {
      "requiresPrOrReviewReadyEvidence": true
    },
    "readyForMerge": {
      "requiresPr": true,
      "requiresPassingRequiredChecks": true,
      "requiresNoOpenHighCriticalReviewFindings": true
    },
    "done": {
      "requiresMergedPr": true
    },
    "blockedWhen": [
      "ci-fails",
      "open-high-critical-review-finding",
      "evidence-ambiguity",
      "contradictory-primary-evidence",
      "unclear-requirement",
      "unsafe-or-missing-permission-for-semantic-decision"
    ],
    "flagWhen": [
      "external-adapter-write-fails",
      "external-adapter-auth-unavailable",
      "supporting-context-disagrees-but-primary-evidence-is-clear"
    ],
    "blockVerdictWhen": [
      "evidence-ambiguity",
      "contradictory-primary-evidence",
      "unclear-requirement",
      "unsafe-or-missing-permission-for-semantic-decision"
    ]
  },
  "forbiddenData": [
    "api keys",
    "oauth material",
    "bearer tokens",
    "cookies",
    "passwords",
    "raw request payloads",
    "raw response payloads",
    "raw transcripts",
    "private screenshots",
    "private browser traces",
    "unrelated private UI"
  ],
  "authority": {
    "capyCanMoveLinearStatus": true,
    "capyCanCommentLinear": true,
    "capyCanPostSlack": true,
    "capyCanMerge": false,
    "buildAgentsCanWriteExternalStatus": false
  }
}
